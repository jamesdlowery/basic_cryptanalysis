90 DEFINT A-Z
100 REM CRYPTANALYSIS SUPPORT PROGRAM
110 REM VERSION 1.0 4 OCT 1988
120 REM
130 REM THIS PROGRAM PROVIDES BASIC CRYPTANALYTIC SUPPORT FUNCTIONS FOR
140 REM THE CRYPTANALYST.
150 REM
160 REM THE PROGRAM IS WRITTEN IN GW-BASIC AND IS INTENDED FOR USE ON IBM PC
170 REM OR COMPATIBLE COMPUTERS.
180 REM
190 REM THE PROGRAM ALLOWS THE USER TO ENTER PLAIN TEXT OR CIPHER TEXT FROM
200 REM THE KEYBOARD OR FROM A DISK FILE.
210 REM
220 REM THE PROGRAM CAN COMPUTE MONOGRAPHIC FREQUENCY COUNTS, DIGRAPHIC FREQUENCY COUNTS,
230 REM INDEX OF COINCIDENCE FOR MONOALPHABETIC AND PERIODIC POLYALPHABETIC SYSTEMS,
240 REM AND PERFORM A MATCHING OPERATION FOR PERIODIC POLYALPHABETIC SYSTEMS.
250 REM
260 REM THE PROGRAM CAN ALSO DETECT REPEATS IN THE TEXT.
270 REM
280 REM THE OUTPUT CAN BE DIRECTED TO THE SCREEN OR TO A PRINTER.
290 REM
300 REM THE PROGRAM CAN SAVE THE OUTPUT TO A DISK FILE.
310 REM
320 REM THE PROGRAM CAN ALSO ENCIPHER OR DECIPHER TEXT USING A USER-SUPPLIED KEY.
330 REM
340 REM NOTE: PRINTER CONTROL CODES ARE FOR EPSON-COMPATIBLE PRINTERS.
350 REM ADJUST AS NEEDED FOR OTHER PRINTERS.
360 REM
370 KEY OFF
380 CLS
390 WIDTH 80
400 COLOR 7,0
410 REM DEFINE PRINTER CONTROL STRINGS
420 PRINTER$ = "LPT1:"
430 FORMFEED$ = CHR$(12)
440 CONDENSED$ = CHR$(15)
450 DC2$ = CHR$(18)
460 ELITE$ = CHR$(27)+"M"
470 PICA$ = CHR$(27)+"P"
480 REM DIMENSION ARRAYS
490 DIM PTEXTD$(25), PTEXTI$(25), CTEXTD$(25), CTEXTI$(25)
500 DIM MFREQ(26), PFREQ(20,27), DIFREQ(26,26), PHIPERI!(20)
510 DIM PMIXFREQ(20,27), SET1!(26), SET2!(26), MATCH!(26)
520 DIM PERPHISUM(20), PERTOTLTR(20)
530 DIM STATUS$(10)
540 NRLINES% = 0
550 REM INITIALIZE STATUS ARRAY
560 FOR I% = 1 TO 10
570 STATUS$(I%) = "NOT DONE"
580 NEXT I%
590 REM MAIN MENU
600 CLS
610 PRINT "CRYPTANALYSIS SUPPORT PROGRAM VERSION 1.0"
620 PRINT
630 PRINT "1. ENTER PLAIN TEXT FROM KEYBOARD"
640 PRINT "2. ENTER PLAIN TEXT FROM DISK"
650 PRINT "3. ENTER CIPHER TEXT FROM KEYBOARD"
660 PRINT "4. ENTER CIPHER TEXT FROM DISK"
670 PRINT "5. ENCIPHER TEXT"
680 PRINT "6. DECIPHER TEXT"
690 PRINT "7. COMPUTE FREQUENCY COUNTS AND IC"
700 PRINT "8. FIND REPEATS"
710 PRINT "9. PRINT RESULTS"
720 PRINT "10. SAVE RESULTS TO DISK"
730 PRINT "11. QUIT"
740 PRINT
750 PRINT "STATUS:"
760 FOR I% = 1 TO 10
770 PRINT I%; ". "; STATUS$(I%)
780 NEXT I%
790 PRINT
800 INPUT "SELECTION "; SELECTION%
810 ON SELECTION% GOSUB 1600, 2000, 2400, 2800, 3200, 3600, 4000, 6000, 6400, 6800, 7200
820 IF SELECTION% <> 11 THEN 600
830 END
840 REM SUBROUTINES START HERE
850 REM PRINTER SETUP
860 OPEN PRINTER$ FOR OUTPUT AS #1
870 PRINT #1, PICA$
880 CLOSE #1
890 RETURN
900 REM ENTER PLAIN TEXT FROM KEYBOARD
1600 CLS
1610 PRINT "ENTER PLAIN TEXT FROM KEYBOARD"
1620 PRINT "ENTER UP TO 25 LINES. END WITH BLANK LINE."
1630 NRLINES% = 0
1640 FOR I% = 1 TO 25
1650 INPUT PTEXTD$(I%)
1660 IF PTEXTD$(I%) = "" THEN GOTO 1700
1670 NRLINES% = NRLINES% + 1
1680 NEXT I%
1690 PRINT "MAXIMUM LINES REACHED"
1700 GOSUB 7600 'CONVERT TO INTERNAL FORMAT
1710 STATUS$(1) = "DONE"
1720 RETURN
1730 REM ENTER PLAIN TEXT FROM DISK
2000 CLS
2010 PRINT "ENTER PLAIN TEXT FROM DISK"
2020 INPUT "FILE NAME "; INFILE$
2030 OPEN INFILE$ FOR INPUT AS #1
2040 NRLINES% = 0
2050 FOR I% = 1 TO 25
2060 IF EOF(1) THEN GOTO 2100
2070 LINE INPUT #1, PTEXTD$(I%)
2080 NRLINES% = NRLINES% + 1
2090 NEXT I%
2100 CLOSE #1
2110 GOSUB 7600
2120 STATUS$(2) = "DONE"
2130 RETURN
2140 REM ENTER CIPHER TEXT FROM KEYBOARD
2400 CLS
2410 PRINT "ENTER CIPHER TEXT FROM KEYBOARD"
2420 PRINT "ENTER UP TO 25 LINES. END WITH BLANK LINE."
2430 NRLINES% = 0
2440 FOR I% = 1 TO 25
2450 INPUT CTEXTD$(I%)
2460 IF CTEXTD$(I%) = "" THEN GOTO 2500
2470 NRLINES% = NRLINES% + 1
2480 NEXT I%
2490 PRINT "MAXIMUM LINES REACHED"
2500 GOSUB 8000 'CONVERT TO INTERNAL FORMAT FOR CIPHER
2510 STATUS$(3) = "DONE"
2520 RETURN
2530 REM ENTER CIPHER TEXT FROM DISK
2800 CLS
2810 PRINT "ENTER CIPHER TEXT FROM DISK"
2820 INPUT "FILE NAME "; INFILE$
2830 OPEN INFILE$ FOR INPUT AS #1
2840 NRLINES% = 0
2850 FOR I% = 1 TO 25
2860 IF EOF(1) THEN GOTO 2900
2870 LINE INPUT #1, CTEXTD$(I%)
2880 NRLINES% = NRLINES% + 1
2890 NEXT I%
2900 CLOSE #1
2910 GOSUB 8000
2920 STATUS$(4) = "DONE"
2930 RETURN
2940 REM ENCIPHER TEXT
3200 IF STATUS$(1) <> "DONE" AND STATUS$(2) <> "DONE" THEN PRINT "NO PLAIN TEXT ENTERED": RETURN
3210 CLS
3220 PRINT "ENCIPHER TEXT"
3230 INPUT "KEY "; KEY$
3240 ' ENCIPHER LOGIC HERE (SIMPLE VIGENERE EXAMPLE)
3250 FOR I% = 1 TO NRLINES%
3260 CTEXTI$(I%) = ""
3270 DEFSNG J
3275 FOR J = 1 TO LEN(PTEXTI$(I%))
3280 P% = ASC(MID$(PTEXTI$(I%),J,1)) - 65
3290 K% = ASC(MID$(KEY$, (INT(J) MOD LEN(KEY$)) + 1,1)) - 65
3300 C% = (P% + K%) MOD 26
3310 CTEXTI$(I%) = CTEXTI$(I%) + CHR$(C% + 65)
3320 NEXT J
3330 NEXT I%
3340 GOSUB 8400 'CONVERT INTERNAL TO DISPLAY FOR CIPHER
3350 STATUS$(5) = "DONE"
3360 RETURN
3370 REM DECIPHER TEXT
3600 IF STATUS$(3) <> "DONE" AND STATUS$(4) <> "DONE" THEN PRINT "NO CIPHER TEXT ENTERED": RETURN
3610 CLS
3620 PRINT "DECIPHER TEXT"
3630 INPUT "KEY "; KEY$
3640 ' DECIPHER LOGIC HERE (SIMPLE VIGENERE EXAMPLE)
3650 FOR I% = 1 TO NRLINES%
3660 PTEXTI$(I%) = ""
3670 DEFSNG J
3675 FOR J = 1 TO LEN(CTEXTI$(I%))
3680 C% = ASC(MID$(CTEXTI$(I%),J,1)) - 65
3690 K% = ASC(MID$(KEY$, (INT(J) MOD LEN(KEY$)) + 1,1)) - 65
3700 P% = (C% - K% + 26) MOD 26
3710 PTEXTI$(I%) = PTEXTI$(I%) + CHR$(P% + 65)
3720 NEXT J
3730 NEXT I%
3740 GOSUB 7600 'CONVERT TO DISPLAY FOR PLAIN
3750 STATUS$(6) = "DONE"
3760 RETURN
3770 REM COMPUTE FREQUENCY COUNTS AND IC
4000 CLS
4010 PRINT "COMPUTE FREQUENCY COUNTS AND IC"
4020 INPUT "TEXT TYPE (P/C) "; Q$
4030 IF Q$ = "P" THEN GOSUB 4400 ELSE GOSUB 4800
4040 INPUT "PERIOD FOR POLY IC (0 FOR MONO) "; PERIOD%
4050 IF PERIOD% = 0 THEN GOSUB 5200 ELSE GOSUB 5600
4060 GOSUB 6000 'DIGRAPHS
4070 STATUS$(7) = "DONE"
4080 RETURN
4090 REM MONO FREQ FOR PLAIN
4400 FOR I% = 1 TO 26
4410 MFREQ(I%) = 0
4420 NEXT I%
4430 TOTLTR% = 0
4440 FOR I% = 1 TO NRLINES%
4450 DEFSNG J
4455 FOR J = 1 TO LEN(PTEXTI$(I%))
4460 L% = ASC(MID$(PTEXTI$(I%),J,1)) - 64
4470 IF L% >= 1 AND L% <= 26 THEN MFREQ(L%) = MFREQ(L%) + 1: TOTLTR% = TOTLTR% + 1
4480 NEXT J
4490 NEXT I%
4500 RETURN
4510 REM MONO FREQ FOR CIPHER
4800 FOR I% = 1 TO 26
4820 MFREQ(I%) = 0
4830 NEXT I%
4840 TOTLTR% = 0
4850 FOR I% = 1 TO NRLINES%
4860 DEFSNG J
4865 FOR J = 1 TO LEN(CTEXTI$(I%))
4870 L% = ASC(MID$(CTEXTI$(I%),J,1)) - 64
4880 IF L% >= 1 AND L% <= 26 THEN MFREQ(L%) = MFREQ(L%) + 1: TOTLTR% = TOTLTR% + 1
4890 NEXT J
4900 NEXT I%
4910 RETURN
4920 REM MONO IC
5200 PHIMONO! = 0
5230 FOR I% = 1 TO 26
5240 PHIMONO! = PHIMONO! + MFREQ(I%) * (MFREQ(I%) - 1)
5250 NEXT I%
5260 IF TOTLTR% * (TOTLTR% - 1) = 0 THEN PHIMONO! = 0 ELSE PHIMONO! = PHIMONO! / (TOTLTR% * (TOTLTR% - 1))
5270 RETURN
5280 REM PERIODIC IC
5600 FOR P% = 1 TO PERIOD%
5610 PERPHISUM(P%) = 0
5620 PERTOTLTR(P%) = 0
5630 FOR I% = 1 TO 26
5640 PFREQ(P%,I%) = 0
5650 NEXT I%
5660 NEXT P%
5670 POSN% = 1
5680 FOR I% = 1 TO NRLINES%
5690 DEFSNG J
5695 FOR J = 1 TO LEN(CTEXTI$(I%))
5700 L% = ASC(MID$(CTEXTI$(I%),J,1)) - 64
5710 IF L% >= 1 AND L% <= 26 THEN PFREQ(POSN%,L%) = PFREQ(POSN%,L%) + 1: PERTOTLTR(POSN%) = PERTOTLTR(POSN%) + 1: POSN% = POSN% + 1: IF POSN% > PERIOD% THEN POSN% = 1
5720 NEXT J
5730 NEXT I%
5740 FOR P% = 1 TO PERIOD%
5750 FOR I% = 1 TO 26
5760 PERPHISUM(P%) = PERPHISUM(P%) + PFREQ(P%,I%) * (PFREQ(P%,I%) - 1)
5770 NEXT I%
5780 IF PERTOTLTR(P%) * (PERTOTLTR(P%) - 1) = 0 THEN PHIPERI!(P%) = 0 ELSE PHIPERI!(P%) = PERPHISUM(P%) / (PERTOTLTR(P%) * (PERTOTLTR(P%) - 1))
5790 NEXT P%
5800 REM MATCH OPERATION
5810 FOR M% = 1 TO PERIOD%
5820 FOR N% = 1 TO 26
5830 IF PERTOTLTR(1) = 0 THEN SET1!(N%) = 0 ELSE SET1!(N%) = PFREQ(1,N%) / PERTOTLTR(1)
5840 IF PERTOTLTR(M%) = 0 THEN SET2!(N%) = 0 ELSE SET2!(N%) = PFREQ(M%,N%) / PERTOTLTR(M%)
5850 MATCH!(M%) = MATCH!(M%) + SET1!(N%) * SET2!(N%)
5860 NEXT N%
5870 NEXT M%
5880 RETURN
5890 REM DIGRAPH FREQ
6000 FOR I% = 1 TO 26
6010 FOR J% = 1 TO 26
6020 DIFREQ(I%,J%) = 0
6030 NEXT J%
6040 NEXT I%
6050 TOTDIG% = 0
6060 FOR I% = 1 TO NRLINES%
6070 DEFSNG J
6075 FOR J = 1 TO LEN(CTEXTI$(I%)) - 1
6080 L1% = ASC(MID$(CTEXTI$(I%),J,1)) - 64
6090 L2% = ASC(MID$(CTEXTI$(I%),J+1,1)) - 64
6100 IF L1% >= 1 AND L1% <= 26 AND L2% >= 1 AND L2% <= 26 THEN DIFREQ(L1%,L2%) = DIFREQ(L1%,L2%) + 1: TOTDIG% = TOTDIG% + 1
6110 NEXT J
6120 NEXT I%
6130 PHIDIG! = 0
6140 FOR I% = 1 TO 26
6150 FOR J% = 1 TO 26
6160 PHIDIG! = PHIDIG! + DIFREQ(I%,J%) * (DIFREQ(I%,J%) - 1)
6170 NEXT J%
6180 NEXT I%
6190 IF TOTDIG% * (TOTDIG% - 1) = 0 THEN PHIDIG! = 0 ELSE PHIDIG! = PHIDIG! / (TOTDIG% * (TOTDIG% - 1))
6200 RETURN
6210 REM FIND REPEATS
6400 CLS
6410 PRINT "FIND REPEATS"
6420 INPUT "MINIMUM REPEAT LENGTH "; MINLEN%
6430 ' REPEAT DETECTION LOGIC (SIMPLE, CHECK FOR DUPLICATES)
6440 FOR LENR% = MINLEN% TO 10
6450 PRINT "REPEATS OF LENGTH "; LENR%
6460 FOR I% = 1 TO NRLINES%
6470 FOR J% = 1 TO LEN(CTEXTI$(I%)) - LENR% + 1
6480 SEG$ = MID$(CTEXTI$(I%),J%,LENR%)
6490 FOR K% = I% TO NRLINES%
6500 STARTK% = 1
6510 IF K% = I% THEN STARTK% = J% + LENR%
6520 FOR L% = STARTK% TO LEN(CTEXTI$(K%)) - LENR% + 1
6530 IF MID$(CTEXTI$(K%),L%,LENR%) = SEG$ THEN PRINT "REPEAT "; SEG$; " AT LINE "; I%; " POS "; J%; " AND LINE "; K%; " POS "; L%
6540 NEXT L%
6550 NEXT K%
6560 NEXT J%
6570 NEXT I%
6580 NEXT LENR%
6590 STATUS$(8) = "DONE"
6600 RETURN
6610 REM PRINT RESULTS
6800 CLS
6820 PRINT "PRINT RESULTS"
6830 INPUT "TO SCREEN OR PRINTER (S/P) "; Q$
6840 IF Q$ = "P" THEN GOSUB 860: DEVICE$ = PRINTER$ ELSE DEVICE$ = "SCR:"
6850 OPEN DEVICE$ FOR OUTPUT AS #1
6860 PRINT #1, "MONOGRAPHIC FREQUENCY COUNT"
6870 FOR I% = 1 TO 26
6880 PRINT #1, CHR$(I%+64); " "; MFREQ(I%)
6890 NEXT I%
6900 PRINT #1, "MONO IC: "; PHIMONO!
6910 IF PERIOD% > 0 THEN PRINT #1, "PERIODIC IC FOR PERIOD "; PERIOD%
6920 IF PERIOD% > 0 THEN FOR P% = 1 TO PERIOD%: PRINT #1, "ALPHA "; P%; " IC "; PHIPERI!(P%): NEXT P%
6930 PRINT #1, "DIGRAPHIC FREQUENCY TABLE"
6940 FOR I% = 1 TO 26
6950 FOR J% = 1 TO 26
6960 PRINT #1, DIFREQ(I%,J%);
6970 NEXT J%
6980 PRINT #1
6990 NEXT I%
7000 PRINT #1, "DIG IC: "; PHIDIG!
7010 IF PERIOD% > 0 THEN PRINT #1, "MATCH SCORES"
7020 IF PERIOD% > 0 THEN FOR M% = 1 TO PERIOD%: PRINT #1, "MATCH "; M%; " "; MATCH!(M%): NEXT M%
7030 IF Q$ = "P" THEN PRINT #1, FORMFEED$
7040 CLOSE #1
7050 STATUS$(9) = "DONE"
7060 RETURN
7070 REM SAVE RESULTS TO DISK
7200 CLS
7210 PRINT "SAVE RESULTS TO DISK"
7220 INPUT "FILE NAME "; OUTFILE$
7230 OPEN OUTFILE$ FOR OUTPUT AS #1
7240 PRINT #1, "MONOGRAPHIC FREQUENCY COUNT"
7250 FOR I% = 1 TO 26
7260 PRINT #1, CHR$(I%+64); " "; MFREQ(I%)
7270 NEXT I%
7280 PRINT #1, "MONO IC: "; PHIMONO!
7290 IF PERIOD% > 0 THEN PRINT #1, "PERIODIC IC FOR PERIOD "; PERIOD%
7300 IF PERIOD% > 0 THEN FOR P% = 1 TO PERIOD%: PRINT #1, "ALPHA "; P%; " IC "; PHIPERI!(P%): NEXT P%
7310 PRINT #1, "DIGRAPHIC FREQUENCY TABLE"
7320 FOR I% = 1 TO 26
7330 FOR J% = 1 TO 26
7340 PRINT #1, DIFREQ(I%,J%);
7350 NEXT J%
7360 PRINT #1
7370 NEXT I%
7380 PRINT #1, "DIG IC: "; PHIDIG!
7390 IF PERIOD% > 0 THEN PRINT #1, "MATCH SCORES"
7400 IF PERIOD% > 0 THEN FOR M% = 1 TO PERIOD%: PRINT #1, "MATCH "; M%; " "; MATCH!(M%): NEXT M%
7410 CLOSE #1
7420 STATUS$(10) = "DONE"
7430 RETURN
7440 REM CONVERT DISPLAY TO INTERNAL FOR PLAIN
7600 FOR I% = 1 TO NRLINES%
7610 PTEXTI$(I%) = ""
7615 DEFSNG J
7620 FOR J = 1 TO LEN(PTEXTD$(I%))
7630 CH$ = UCASE$(MID$(PTEXTD$(I%),J,1))
7640 IF CH$ >= "A" AND CH$ <= "Z" THEN PTEXTI$(I%) = PTEXTI$(I%) + CH$
7650 NEXT J
7660 NEXT I%
7670 RETURN
7680 REM CONVERT DISPLAY TO INTERNAL FOR CIPHER
8000 FOR I% = 1 TO NRLINES%
8010 CTEXTI$(I%) = ""
8015 DEFSNG J
8020 FOR J = 1 TO LEN(CTEXTD$(I%))
8030 CH$ = UCASE$(MID$(CTEXTD$(I%),J,1))
8040 IF CH$ >= "A" AND CH$ <= "Z" THEN CTEXTI$(I%) = CTEXTI$(I%) + CH$
8050 NEXT J
8060 NEXT I%
8070 RETURN
8080 REM CONVERT INTERNAL TO DISPLAY FOR CIPHER
8400 FOR I% = 1 TO NRLINES%
8410 CTEXTD$(I%) = CTEXTI$(I%)
8420 NEXT I%
8430 RETURN
